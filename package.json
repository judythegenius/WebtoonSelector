{
  "name": "react-example",
  "private": true,
  "version": "0.0.0",
  "type": "module",
 "scripts": {
  "dev": "granite dev",
  "build": "ait build",
  "build:web": "vite build --outDir dist/client && npx esbuild server.ts --bundle --platform=node --outfile=dist/server.js --format=cjs --external:express --external:dotenv --external:vite --external:esbuild --external:cors --define:import.meta.url=\"\"",
  "postbuild:web": "node -e \"const fs=require('fs'); fs.copyFileSync('dist/server.js','dist/server.cjs');\"",
  "start": "node dist/server.cjs",
  "deploy": "ait deploy"
},
  "dependencies": {
    "@apps-in-toss/web-framework": "^2.10.6",
    "@emotion/react": "^11.14.0",
    "@google/genai": "^2.4.0",
    "@tailwindcss/vite": "^4.1.14",
    "@toss/tds-mobile": "^2.5.0",
    "@toss/tds-mobile-ait": "^2.5.0",
    "@vitejs/plugin-react": "^5.0.4",
    "dotenv": "^17.2.3",
    "express": "^4.21.2",
    "lucide-react": "^0.546.0",
    "motion": "^12.23.24",
    "react": "18.3.1",
    "react-dom": "18.3.1",
    "vite": "^6.2.3",
    "cors": "^2.8.5"
  },
  "devDependencies": {
    "@types/express": "^4.17.21",
    "@types/node": "^22.14.0",
    "@types/cors": "^2.8.17",
    "autoprefixer": "^10.4.21",
    "esbuild": "^0.25.0",
    "tailwindcss": "^4.1.14",
    "tsx": "^4.21.0",
    "typescript": "~5.8.2",
    "vite": "^6.2.3"
  }
}
